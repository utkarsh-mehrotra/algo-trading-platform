{
  "title": "Algo Trading Platform",
  "panels": [
    {
      "title": "P99 Signal-to-Order Latency (ms)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(algo_latency_signal_to_order_seconds_bucket[5m])) * 1000",
          "legendFormat": "P99 Latency (ms)"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "value": 0, "color": "green" },
          { "value": 300, "color": "red" }
        ]
      }
    },
    {
      "title": "Orders Executed",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(algo_orders_placed_total[1m])",
          "legendFormat": "Orders / min"
        }
      ]
    }
  ]
}
